# ---------------------------------------------------------------
# FinScope — Environment Variables Template
# Copy to `.env` locally, or paste these into Vercel
# Project Settings → Environment Variables (Production / Preview / Dev).
# ---------------------------------------------------------------

# --- Public (exposed to the browser via Vite) ---------------------
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# --- Server-side (used by SSR / server functions) ----------------
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-anon-key"

# Service role — server-only, NEVER prefix with VITE_
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# --- AI Gateway (used by Supabase Edge Functions) ----------------
# Auto-provisioned when using Lovable Cloud. Required only if you
# self-host the edge functions outside Lovable.
LOVABLE_API_KEY="your-lovable-ai-gateway-key"
